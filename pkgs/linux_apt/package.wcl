package "linux_apt" {
  description = "Manage packages on apt/dpkg systems"

  resource "package" {
    description = "Ensure an apt package is installed or absent"
    script = "resources/package.wisp"
    concurrency = "exclusive"
    param "name" { description = "Package name" type = "string" required = true }
    param "ensure" { description = "Desired state: :present or :absent" type = "symbol" default = :present }
    param "version" { description = "Optional version to pin when present; empty means any version" type = "string" default = "" }
  }

  resource "cache_updated" {
    description = "Run apt-get update once per marker"
    script = "resources/cache_updated.wisp"
    concurrency = "exclusive"
    param "marker" { description = "Marker path used for idempotence" type = "string" default = "/var/lib/config-weave/package-cache-updated" }
  }

  resource "repository" {
    description = "Ensure an apt sources.list.d file exists or is absent"
    script = "resources/repository.wisp"
    concurrency = "exclusive"
    param "name" { description = "Repository file basename without .list" type = "string" required = true }
    param "ensure" { description = "Desired state: :present or :absent" type = "symbol" default = :present }
    param "content" { description = "Repository file content (required when present)" type = "string" default = "" }
  }

  resource "signing_key" {
    description = "Ensure an apt signing key under /etc/apt/keyrings exists or is absent"
    script = "resources/signing_key.wisp"
    concurrency = "exclusive"
    param "name" { description = "Keyring basename" type = "string" required = true }
    param "ensure" { description = "Desired state: :present or :absent (removes both .asc and .gpg)" type = "symbol" default = :present }
    param "content" { description = "ASCII-armored GPG public key (required when present)" type = "string" default = "" }
    param "dearmor" { description = "Also produce a binary .gpg keyring via gpg --dearmor" type = "bool" default = true }
  }

  resource "hold" {
    description = "Ensure an apt-mark hold on a package is present or absent"
    script = "resources/hold.wisp"
    concurrency = "exclusive"
    param "name" { description = "Package name" type = "string" required = true }
    param "ensure" { description = "Desired state: :present (held) or :absent (not held)" type = "symbol" default = :present }
  }

  resource "debconf_selection" {
    description = "Pre-seed a debconf answer"
    script = "resources/debconf_selection.wisp"
    concurrency = "exclusive"
    param "package" { description = "Owning package name" type = "string" required = true }
    param "question" { description = "debconf question name" type = "string" required = true }
    param "vtype" { description = "Answer type (string, boolean, select, ...)" type = "string" default = "string" }
    param "value" { description = "Answer value" type = "string" required = true }
  }

  test "existing_package" {
    description = "package can detect an installed Debian package"
    image = "debian:12"
    # Shares one container with the other debian tests (all debian:12, and
    # they touch unrelated state: an installed-package check vs. repo files).
    group = "debian"

    step "base-files-installed" {
      description = "base-files is already installed in Debian"
      resource = "package"
      expect = "already_configured"
      properties { name = "base-files" }
    }
  }

  // The absent steps converge on files seeded during setup (run 1 checks
  // every step before any apply).
  test "repositories_and_keys_converge" {
    description = "repository and signing_key add and remove converge"
    image = "debian:12"
    group = "debian"
    setup = "mkdir -p /etc/apt/sources.list.d /etc/apt/keyrings && echo 'deb http://stale.invalid/debian bookworm main' > /etc/apt/sources.list.d/cw-stale.list && echo stale-key > /etc/apt/keyrings/cw-stale.asc"
    verify = "tests/apt_repository_verify.wisp"

    step "repo" {
      description = "Write repository file"
      resource = "repository"
      properties {
        name = "config-weave-test"
        content = "deb http://deb.debian.org/debian bookworm main\n"
      }
    }

    step "rm_repo" {
      description = "Remove the seeded stale repository"
      resource = "repository"
      properties { name = "cw-stale" ensure = :absent }
    }

    step "key" {
      description = "Install an apt signing key (armored, no dearmor)"
      resource = "signing_key"
      properties {
        name = "cw-test"
        dearmor = false
        content = "-----BEGIN PGP PUBLIC KEY BLOCK-----\n\nmDMEAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA\n-----END PGP PUBLIC KEY BLOCK-----\n"
      }
    }

    step "rm_key" {
      description = "Remove the seeded stale key"
      resource = "signing_key"
      properties { name = "cw-stale" ensure = :absent }
    }
  }

  // Untested by design: cache_updated hits the network (apt-get update),
  // which does not converge honestly in an offline container.
  //
  // The apt steps are chained with `requires`: `exclusive` only serializes
  // steps of the SAME resource type, but package/hold/debconf all contend
  // for the one dpkg lock, so mixing them concurrently fails.
  // Playbooks mixing these resources need the same ordering.
  test "apt_state_changes" {
    description = "Removal, holds and debconf selections converge offline on Debian"
    image = "debian:12"
    group = "debian"
    setup = "apt-mark hold gzip >/dev/null"
    verify = "tests/apt_state_verify.wisp"

    step "remove" {
      description = "Remove the preinstalled tzdata package (offline)"
      resource = "package"
      properties { name = "tzdata" ensure = :absent }
    }

    step "hold" {
      description = "Hold base-files at its current version"
      resource = "hold"
      requires = ["remove"]
      properties { name = "base-files" }
    }

    step "unhold" {
      description = "Release the hold setup placed on gzip"
      resource = "hold"
      requires = ["hold"]
      properties { name = "gzip" ensure = :absent }
    }

    step "debconf" {
      description = "Pre-seed a debconf answer"
      resource = "debconf_selection"
      requires = ["unhold"]
      properties { package = "cw-test" question = "cw-test/enable" vtype = "boolean" value = "true" }
    }
  }
}
